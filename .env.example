# STS2 Coach — environment variables
# Copy to `.env` and fill in. Never commit `.env`.

# OpenRouter handles all LLM calls (vision + reasoning)
# Get a key: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# OpenAI handles TTS (tts-1 is cheap and fast)
# Get a key: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Default model slug passed to OpenRouter. Override from the tray menu at runtime.
# Known-good vision-capable models (refreshed Apr 2026):
#   anthropic/claude-opus-4.7         (flagship, slow)
#   anthropic/claude-sonnet-4.6       (recommended default)
#   anthropic/claude-haiku-4.5        (fast/cheap)
#   openai/gpt-5.4                    (flagship)
#   openai/gpt-5.4-mini               (balanced)
#   openai/gpt-5.4-nano               (fastest)
#   google/gemini-3-pro-preview       (flagship)
#   google/gemini-3-flash-preview     (fast/cheap)
DEFAULT_MODEL=anthropic/claude-sonnet-4.6

# TTS provider: "openai" or "say" (macOS built-in, free)
TTS_PROVIDER=openai
TTS_VOICE=onyx
# For openai tts-1; alternatives: alloy, echo, fable, nova, shimmer, onyx

# Optional: override save-file directory (auto-detected on Mac by default)
# STS2_SAVE_DIR=/Users/you/Library/Application Support/SlayTheSpire2

# Logging
LOG_LEVEL=info
